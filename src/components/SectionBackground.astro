---
/**
 * SectionBackground — セクションの背景色と上下フリル波を管理するコンポーネント。
 *
 * 【波の実装方式】
 *   従来の「200%幅SVGをtranslateXでループ」方式は、画面幅でアーチ形状が拡縮する問題がある。
 *   代わりに CSS background-image（SVGデータURL）+ background-repeat: repeat-x を使い、
 *   アーチを固定ピクセルでタイリングする。アニメーションは background-position-x のシフトで実現。
 *
 *   → 画面幅が変わってもアーチ幅 240px / 大波 360px が常に一定 ✓
 *
 * 【境界の継ぎ目なし】
 *   波の fill 色とセクション背景グラデーションの上・下端色を完全に一致させることで、
 *   矩形の境界線が見えなくなる。グラデーションは 180deg（真上→真下）限定。
 */
import { css, cx } from "@styled/css";
import {
	SECTION_LIGHT_BG,
	SECTION_LIGHT_TOP,
	SECTION_LIGHT_BOT,
	SECTION_DARK_BG,
} from "@consts/theme";

interface Props {
	id?: string;
	animate?: boolean;   // true でコンテンツに floatIn アニメーション
	dark?: boolean;      // true でダークテーマ（サーバーセクション）
	bigTop?: boolean;    // 大きい上波（About 前後）
	bigBottom?: boolean; // 大きい下波（About 前後）
	hasBottom?: boolean; // false で下波を省略
}

const {
	id,
	animate   = true,
	dark      = false,
	bigTop    = false,
	bigBottom = false,
	hasBottom = true,
} = Astro.props;

// ===== テーマ別カラー =====
const bgStyle    = dark ? SECTION_DARK_BG  : SECTION_LIGHT_BG;
const topSvgFill = dark ? SECTION_DARK_BG  : SECTION_LIGHT_TOP; // 上端色と一致
const botSvgFill = dark ? SECTION_DARK_BG  : SECTION_LIGHT_BOT; // 下端色と一致

// ===== 1アーチ分のSVGパス =====
// 通常: 240×64、大: 360×128（画面幅によらず固定ピクセルでタイル）
const TOP_ONE_FILL   = "M0,64 L0,42 C80,6 160,6 240,42 L240,64 Z";
const TOP_ONE_STROKE = "M0,42 C80,6 160,6 240,42";
const BOT_ONE_FILL   = "M0,0 L0,22 C80,58 160,58 240,22 L240,0 Z";
const BOT_ONE_STROKE = "M0,22 C80,58 160,58 240,22";

const BIG_TOP_ONE_FILL   = "M0,128 L0,90 C120,8 240,8 360,90 L360,128 Z";
const BIG_TOP_ONE_STROKE = "M0,90 C120,8 240,8 360,90";
const BIG_BOT_ONE_FILL   = "M0,0 L0,38 C120,120 240,120 360,38 L360,0 Z";
const BIG_BOT_ONE_STROKE = "M0,38 C120,120 240,120 360,38";

// SVGデータURL生成（1アーチ分 → repeat-x でタイル）
function waveUrl(fill: string, fillPath: string, strokePath: string, w: number, h: number): string {
	const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 ${w} ${h}'><path d='${fillPath}' fill='${fill}'/><path d='${strokePath}' fill='none' stroke='rgba(125,211,252,0.85)' stroke-width='4' stroke-linecap='round' stroke-dasharray='0 18'/></svg>`;
	return `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
}

const topUrl = waveUrl(
	topSvgFill,
	bigTop ? BIG_TOP_ONE_FILL   : TOP_ONE_FILL,
	bigTop ? BIG_TOP_ONE_STROKE : TOP_ONE_STROKE,
	bigTop ? 360 : 240,
	bigTop ? 128 : 64,
);
const botUrl = waveUrl(
	botSvgFill,
	bigBottom ? BIG_BOT_ONE_FILL   : BOT_ONE_FILL,
	bigBottom ? BIG_BOT_ONE_STROKE : BOT_ONE_STROKE,
	bigBottom ? 360 : 240,
	bigBottom ? 128 : 64,
);

// ===== PandaCSS =====
const sectionClass = css({ position: "relative" });

// 波要素の共通スタイル（background-image + repeat-x でタイル表示）
const waveBase = css({
	position: "absolute",
	left: 0,
	width: "100%",
	pointerEvents: "none",
	zIndex: 5,
	backgroundRepeat: "repeat-x",
	backgroundPosition: "0 0",
});

// 上波: top=-(ベースy) でベースラインをセクション上端に合わせる
const topNormal = css({ top: "-42px",  height: "64px",  backgroundSize: "240px 64px"  });
const topBig    = css({ top: "-90px",  height: "128px", backgroundSize: "360px 128px" });
// 下波: bottom=-(height-ベースy) でベースラインをセクション下端に合わせる
const botNormal = css({ bottom: "-42px", height: "64px",  backgroundSize: "240px 64px"  });
const botBig    = css({ bottom: "-90px", height: "128px", backgroundSize: "360px 128px" });

const topWaveClass = cx(waveBase, bigTop    ? topBig    : topNormal);
const botWaveClass = cx(waveBase, bigBottom ? botBig    : botNormal);

// アニメーション名: background-position-x を1アーチ分シフトしてシームレスループ
const topAnim  = bigTop    ? "waveBig" : "waveNorm";
const botAnim  = bigBottom ? "waveBig" : "waveNorm";
const topSpeed = bigTop    ? "12s" : "10s";
const botSpeed = bigBottom ? "13s" : "11s";
---

<section
	id={id}
	class={sectionClass}
	style={`background: ${bgStyle};`}
	data-section-theme={dark ? "dark" : "light"}
>
	<!-- 上波: 固定ピクセルアーチが repeat-x でタイル、background-position-x アニメーション -->
	<div
		class={topWaveClass}
		style={`background-image: ${topUrl}; animation: ${topAnim} ${topSpeed} linear infinite;`}
		aria-hidden="true"
	></div>

	<!-- コンテンツ -->
	{animate ? (
		<div data-animate>
			<slot />
		</div>
	) : (
		<slot />
	)}

	<!-- 下波: 逆方向スクロール（reverse）で視覚的なリズムを加える -->
	{hasBottom && (
		<div
			class={botWaveClass}
			style={`background-image: ${botUrl}; animation: ${botAnim} ${botSpeed} linear infinite reverse;`}
			aria-hidden="true"
		></div>
	)}
</section>
