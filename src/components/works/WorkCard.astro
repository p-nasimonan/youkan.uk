---
import { css, cx } from "@styled/css";
import { getImage } from "astro:assets";
import videomockSrc from "../../assets/hero/videomock.png";

interface Props {
	slug: string;
	title: string;
	description: string;
	image?: string;
	tags?: string[];
	/** 右寄せ(true) / 左寄せ(false) — ピークレイアウト用 */
	peekRight?: boolean;
}

const { slug, title, description, image, tags = [], peekRight = false } = Astro.props;

const fallbackImage = (await getImage({ src: videomockSrc, format: "webp", quality: 85 })).src;
const imgSrc = image ?? fallbackImage;

const wrapClass = css({
	display: "block",
	textDecoration: "none",
	color: "inherit",
	// フレーム
	borderRadius: "28px",
	padding: "10px",
	background: "linear-gradient(135deg, rgba(255,200,220,0.7) 0%, rgba(180,220,255,0.7) 100%)",
	boxShadow: "0 4px 24px rgba(200,150,200,0.18)",
	backdropFilter: "blur(6px)",
	transition: "padding 0.4s cubic-bezier(0.4,0,0.2,1), box-shadow 0.4s ease",
	cursor: "pointer",
	_hover: {
		padding: "3px",
		boxShadow: "0 8px 40px rgba(180,120,200,0.32)",
	},
});

const innerClass = css({
	position: "relative",
	overflow: "hidden",
	borderRadius: "20px",
	aspectRatio: "16/9",
	background: "rgba(255,255,255,0.4)",
});

const imgClass = css({
	width: "100%",
	height: "100%",
	objectFit: "cover",
	display: "block",
	transition: "transform 0.5s cubic-bezier(0.4,0,0.2,1)",
	"a:hover &": { transform: "scale(1.07)" },
});

const overlayClass = css({
	position: "absolute",
	inset: 0,
	background: "linear-gradient(to top, rgba(80,40,80,0.72) 0%, transparent 60%)",
	opacity: 0,
	transition: "opacity 0.35s ease",
	"a:hover &": { opacity: 1 },
});

const titleClass = css({
	position: "absolute",
	bottom: "1rem",
	left: "1.2rem",
	right: "1.2rem",
	color: "white",
	fontSize: "1.3rem",
	fontWeight: "bold",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	opacity: 0,
	transform: "translateY(10px)",
	transition: "opacity 0.35s ease, transform 0.35s ease",
	"a:hover &": { opacity: 1, transform: "translateY(0)" },
});

const tagsClass = css({
	position: "absolute",
	top: "0.8rem",
	right: "0.8rem",
	display: "flex",
	gap: "0.3rem",
	flexWrap: "wrap",
	justifyContent: "flex-end",
	opacity: 0,
	transition: "opacity 0.35s ease",
	"a:hover &": { opacity: 1 },
});

const tagClass = css({
	fontSize: "0.7rem",
	padding: "0.15rem 0.5rem",
	borderRadius: "999px",
	background: "rgba(255,255,255,0.85)",
	color: "#7a3a7a",
	fontWeight: "bold",
});
---

<a href={`/works/${slug}`} class={wrapClass}>
	<div class={innerClass}>
		<img src={imgSrc} alt={title} class={imgClass} loading="lazy" />
		<div class={overlayClass} aria-hidden="true"></div>
		<div class={tagsClass} aria-hidden="true">
			{tags.map((t) => <span class={tagClass}>{t}</span>)}
		</div>
		<p class={titleClass}>{title}</p>
	</div>
</a>
