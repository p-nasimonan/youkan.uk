---
/**
 * WaveDivider — frill-style animated wave between sections.
 *
 * Place at the TOP of a section. `fill` should match THIS section's
 * background color so the wave "pours in" over the previous section.
 *
 * The wrapper is 200% wide with two identical SVG copies, animated
 * by `waveScroll` (defined in GlobalLayout is:global) for a seamless loop.
 */
interface Props {
	fill: string;
	big?: boolean;
}

const { fill, big = false } = Astro.props;

// Regular frill: 24 peaks × 120px, 64px tall
const path =
	"M0,64 L0,38 C60,8 120,64 180,38 C240,8 300,64 360,38 C420,8 480,64 540,38 C600,8 660,64 720,38 C780,8 840,64 900,38 C960,8 1020,64 1080,38 C1140,8 1200,64 1260,38 C1320,8 1380,64 1440,38 C1500,8 1560,64 1620,38 C1680,8 1740,64 1800,38 C1860,8 1920,64 1980,38 C2040,8 2100,64 2160,38 C2220,8 2280,64 2340,38 C2400,8 2460,64 2520,38 C2580,8 2640,64 2700,38 C2760,8 2820,64 2880,38 L2880,64 Z";
const strokePath =
	"M0,38 C60,8 120,64 180,38 C240,8 300,64 360,38 C420,8 480,64 540,38 C600,8 660,64 720,38 C780,8 840,64 900,38 C960,8 1020,64 1080,38 C1140,8 1200,64 1260,38 C1320,8 1380,64 1440,38 C1500,8 1560,64 1620,38 C1680,8 1740,64 1800,38 C1860,8 1920,64 1980,38 C2040,8 2100,64 2160,38 C2220,8 2280,64 2340,38 C2400,8 2460,64 2520,38 C2580,8 2640,64 2700,38 C2760,8 2820,64 2880,38";

// Big irregular frill: exaggerated varying peaks, 128px tall (for Around About Me)
const bigPath =
	"M0,128 L0,76 C30,13 90,108 150,55 C190,10 240,90 310,45 C370,22 420,92 490,50 C530,4 580,82 650,55 C700,18 760,94 830,38 C870,6 930,74 1000,48 C1050,16 1110,90 1180,42 C1220,4 1280,74 1440,76 C1470,13 1530,108 1590,55 C1630,10 1680,90 1750,45 C1810,22 1860,92 1930,50 C1970,4 2020,82 2090,55 C2140,18 2200,94 2270,38 C2310,6 2370,74 2440,48 C2490,16 2550,90 2620,42 C2660,4 2720,74 2880,76 L2880,128 Z";
const bigStrokePath =
	"M0,76 C30,13 90,108 150,55 C190,10 240,90 310,45 C370,22 420,92 490,50 C530,4 580,82 650,55 C700,18 760,94 830,38 C870,6 930,74 1000,48 C1050,16 1110,90 1180,42 C1220,4 1280,74 1440,76 C1470,13 1530,108 1590,55 C1630,10 1680,90 1750,45 C1810,22 1860,92 1930,50 C1970,4 2020,82 2090,55 C2140,18 2200,94 2270,38 C2310,6 2370,74 2440,48 C2490,16 2550,90 2620,42 C2660,4 2720,74 2880,76";

const usePath = big ? bigPath : path;
const useStrokePath = big ? bigStrokePath : strokePath;
const viewBox = big ? "0 0 2880 128" : "0 0 2880 64";
const wrapperClass = big ? "wave-wrapper wave-wrapper--big" : "wave-wrapper";
---

<div class={wrapperClass} aria-hidden="true">
	<svg class="wave-svg" viewBox={viewBox} preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
		<path d={usePath} fill={fill} />
		<!-- Pink frill stroke line in same SVG so it always aligns with the fill wave -->
		<path d={useStrokePath} fill="none" stroke="rgba(255,150,180,0.75)" stroke-width="1.5" />
	</svg>
</div>
