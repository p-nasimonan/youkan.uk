---
import { css } from "@styled/css";

// このセクションは背景なし（透過）で動画が見える。
// 上下の大きいフリル波は隣接する LinksSection・WorksSection が担当する。

const sectionStyles = css({
	minHeight: "100vh",
	padding: "5rem 2rem 5rem",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	position: "relative",
	zIndex: 1,
	// background なし: 動画がそのまま透けて見える
});

const containerGrid = css({
	display: "grid",
	gridTemplateColumns: "1fr",
	gap: "4rem",
	maxWidth: "1000px",
	width: "100%",
	alignItems: "center",
	md: {
		gridTemplateColumns: "1fr 1fr",
	},
});

// ポラロイド風写真カード
const polaroidStyles = css({
	backgroundColor: "white",
	padding: "1rem 1rem 3rem 1rem",
	boxShadow: "0 4px 15px rgba(0,0,0,0.1)",
	transform: "rotate(-3deg)",
	transition: "transform 0.3s ease",
	_hover: {
		transform: "rotate(0deg) scale(1.02)",
		boxShadow: "0 8px 25px rgba(0,0,0,0.15)",
	},
});

const polaroidImage = css({
	width: "100%",
	aspectRatio: "3/4",
	backgroundColor: "#ddd",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	color: "#888",
	fontSize: "1.2rem",
	marginBottom: "1rem",
});

const infoStyles = css({
	display: "flex",
	flexDirection: "column",
	gap: "1.5rem",
});

// 少し傾けた自己紹介カード
const bioStyles = css({
	fontSize: "1.2rem",
	lineHeight: "1.8",
	transform: "rotate(1deg)",
	backgroundColor: "white",
	padding: "2rem",
	borderRadius: "20px",
	boxShadow: "2px 2px 0px rgba(0,0,0,0.05)",
	border: "2px dashed #e0e0e0",
});
---

<!-- data-animate: セクション全体がスクロール時にフェードイン -->
<section id="about" class={sectionStyles} data-animate>
	<div class={containerGrid}>
		<!-- 左: ポラロイド写真 -->
		<div class={polaroidStyles}>
			<div class={polaroidImage}>Image Placeholder</div>
			<div
				class={css({
					textAlign: "center",
					fontFamily: '"Zen Maru Gothic", sans-serif',
					fontWeight: "bold",
				})}
			>
				#家猫ようかん #ぷぷりえ
			</div>
		</div>

		<!-- 右: 自己紹介 -->
		<div class={infoStyles}>
			<h2
				class={css({
					fontSize: "2.5rem",
					marginBottom: "1rem",
					color: "#4a4a4a",
					fontFamily: '"Zen Maru Gothic", sans-serif',
				})}
			>
				About me
			</h2>

			<div class={bioStyles}>
				<p>ようかんです。</p>
				<p>にゃんにゃん</p>
				<p>なんでもやさんです！</p>
			</div>
		</div>
	</div>
</section>
