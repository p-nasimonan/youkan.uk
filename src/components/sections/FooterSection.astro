---
import { css } from "@styled/css";

const footerStyles = css({
	padding: "3rem 2rem",
	textAlign: "center",
	background: "linear-gradient(180deg, #2a1a2e 0%, #1a1a2e 100%)",
	color: "white",
	position: "relative",
});

const navStyles = css({
	display: "flex",
	justifyContent: "center",
	gap: "2rem",
	flexWrap: "wrap",
	marginBottom: "2rem",
});

const navLinkStyles = css({
	color: "rgba(255,255,255,0.7)",
	textDecoration: "none",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	fontSize: "0.95rem",
	transition: "color 0.2s ease",
	_hover: { color: "rgba(255,200,220,1)" },
});

const copyrightStyles = css({
	fontSize: "0.85rem",
	color: "rgba(255,255,255,0.4)",
	fontFamily: '"Zen Maru Gothic", sans-serif',
});
---

<footer class={footerStyles}>
	<nav class={navStyles}>
		<a href="/#links"  class={navLinkStyles}>リンク</a>
		<a href="/#works"  class={navLinkStyles}>作品</a>
		<a href="/#server" class={navLinkStyles}>サーバー</a>
		<a href="/works"   class={navLinkStyles}>作品一覧</a>
	</nav>
	<p class={copyrightStyles}>&copy; 2026 Youkan</p>
</footer>
