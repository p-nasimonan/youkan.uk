---
import { css } from "@styled/css";
import SectionBackground from "../SectionBackground.astro";

// 将来的にここにコンテンツを追加する
// type Work = { title: string; description: string; url?: string; tags: string[]; image?: string; };
// const works: Work[] = [];

// SectionBackground が position/overflow/backgroundColor を担当するためここでは不要
const innerStyles = css({
	minHeight: "60vh",
	padding: "9rem 2rem 4rem",  // 上波（128px）分の余白を確保
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	zIndex: 1,
});

const containerStyles = css({
	maxWidth: "900px",
	width: "100%",
	textAlign: "center",
});

const titleStyles = css({
	fontSize: "2.5rem",
	fontWeight: "bold",
	marginBottom: "3rem",
	color: "#4a4a4a",
	fontFamily: '"Zen Maru Gothic", sans-serif',
});

const placeholderStyles = css({
	backgroundColor: "white",
	borderRadius: "24px",
	padding: "4rem 2rem",
	border: "2px dashed rgba(0, 0, 0, 0.1)",
	color: "#888",
	fontSize: "1.1rem",
	fontFamily: '"Zen Maru Gothic", sans-serif',
});
---

<!-- bigTop: 上波を大きくしてAboutセクション（透過）との境界を強調 -->
<!-- hasBottom={false}: 下波は ServerSection の上波が担当するため不要 -->
<SectionBackground fill="white" id="works" bigTop hasBottom={false}>
	<div class={innerStyles}>
		<div class={containerStyles}>
			<h2 class={titleStyles}>作品</h2>
			<div class={placeholderStyles}>
				<p>準備中</p>
			</div>
		</div>
	</div>
</SectionBackground>
