---
import { css } from "@styled/css";
import SectionBackground from "../SectionBackground.astro";

// SectionBackground が position/overflow/backgroundColor を担当するためここでは不要
const innerStyles = css({
	minHeight: "100vh",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	position: "relative",  // backgroundOverlay の基準点
	zIndex: 2,
});

// 背景を暗くするオーバーレイ
const backgroundOverlay = css({
	position: "absolute",
	top: 0,
	left: 0,
	width: "100%",
	height: "100%",
	backgroundColor: "#222",
	zIndex: 1,
});

const container = css({
	position: "relative",
	zIndex: 2,
	maxWidth: "1200px",
	width: "100%",
	padding: "2rem",
	textAlign: "center",
});

const titleStyles = css({
	fontFamily: '"Zen Maru Gothic", sans-serif',
	fontSize: "3rem",
	marginBottom: "3rem",
	textShadow: "0 0 10px rgba(255,255,255,0.5)",
	color: "white",
});

const serverRackStyles = css({
	position: "relative",
	width: "80%",
	maxWidth: "600px",
	margin: "0 auto",
	aspectRatio: "3/5",
	border: "2px solid #555",
	backgroundColor: "#222",
	borderRadius: "10px",
	boxShadow: "0 0 30px rgba(0, 255, 0, 0.1)",
	backgroundImage: "repeating-linear-gradient(0deg, #1a1a1a, #1a1a1a 19px, #333 20px)",
});

---

<!-- hasBottom=false: フッターとの間に下波は不要 -->
<SectionBackground fill="#222" id="server" hasBottom={false}>
	<div class={innerStyles}>
		<div class={backgroundOverlay}></div>

		<!-- 背景装飾テキスト -->
		<div
			class={css({
				position: "absolute",
				zIndex: 0,
				color: "#444",
				fontSize: "10rem",
				fontWeight: "bold",
				opacity: 0.1,
			})}
		>
			SERVER ROOM
		</div>

		<div class={container}>
			<h2 class={titleStyles}>サーバー</h2>
			<p
				class={css({
					marginBottom: "2rem",
					fontSize: "1.2rem",
					color: "#ccc",
				})}
			>
				Hover over the lights!
			</p>

			<div class={serverRackStyles}>
				<!-- 手書き風の矢印テキスト -->
				<div
					class={css({
						position: "absolute",
						top: "22%",
						left: "10%",
						color: "white",
						transform: "rotate(-20deg)",
						fontFamily: '"Zen Maru Gothic"',
					})}
				>
					Fast! →
				</div>
			</div>
		</div>
	</div>
</SectionBackground>
