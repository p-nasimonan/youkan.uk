---
import { css } from "@styled/css";
import { socialLinks } from "@consts/links";
import LinkIcon from "../LinkIcon.astro";
import SectionBackground from "../SectionBackground.astro";

// --- OGP画像取得（SSR） ---
function extractOgImage(html: string): string | null {
	let m = html.match(
		/<meta[^>]+property=["']og:image["'][^>]+content=["']([^"']+)["']/i,
	);
	if (m?.[1]) return m[1];
	m = html.match(
		/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:image["']/i,
	);
	return m?.[1] ?? null;
}

const ogpImages: Record<string, string | null> = {};
await Promise.all(
	socialLinks
		.filter((l) => l.icon === "ogp")
		.map(async (link) => {
			try {
				const controller = new AbortController();
				const tid = setTimeout(() => controller.abort(), 3000);
				const res = await fetch(link.url, {
					signal: controller.signal,
					headers: { "User-Agent": "facebookexternalhit/1.1" },
				});
				clearTimeout(tid);
				ogpImages[link.url] = extractOgImage(await res.text());
			} catch {
				ogpImages[link.url] = null;
			}
		}),
);

const featured = socialLinks.filter((l) => l.isHomeServer);
const others = socialLinks.filter((l) => !l.isHomeServer);

// --- スタイル ---
// SectionBackground が position/overflow/backgroundColor を担当するためここでは不要
const innerStyles = css({
	padding: "5rem 2rem 4rem",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	zIndex: 1,
});

const containerStyles = css({
	maxWidth: "900px",
	width: "100%",
});

const titleStyles = css({
	fontSize: "2.5rem",
	fontWeight: "bold",
	textAlign: "center",
	marginBottom: "3rem",
	color: "#4a4a4a",
	fontFamily: '"Zen Maru Gothic", sans-serif',
});

// 自宅サーバーリンク用の大きめカード
const featuredCardStyles = css({
	display: "block",
	textDecoration: "none",
	backgroundColor: "rgba(255, 255, 255, 0.85)",
	backdropFilter: "blur(16px)",
	borderRadius: "24px",
	padding: "2rem 2.5rem",
	marginBottom: "1.5rem",
	boxShadow: "0 4px 20px rgba(0,0,0,0.07)",
	color: "#333",
	transition: "transform 0.3s ease, box-shadow 0.3s ease",
	_hover: {
		transform: "translateY(-4px)",
		boxShadow: "0 8px 32px rgba(0,0,0,0.12)",
	},
});

// グリッド配置
const gridStyles = css({
	display: "grid",
	gridTemplateColumns: "repeat(2, 1fr)",
	gap: "1rem",
	sm: { gridTemplateColumns: "repeat(3, 1fr)" },
	md: { gridTemplateColumns: "repeat(4, 1fr)" },
});

// 通常リンクカード（アイコン＋テキスト）
const cardStyles = css({
	display: "flex",
	flexDirection: "column",
	alignItems: "center",
	gap: "0.6rem",
	textDecoration: "none",
	backgroundColor: "rgba(255, 255, 255, 0.85)",
	backdropFilter: "blur(16px)",
	borderRadius: "18px",
	padding: "1.5rem 1rem",
	color: "#333",
	boxShadow: "0 3px 16px rgba(0,0,0,0.07)",
	border: "1.5px solid rgba(255,255,255,0.9)",
	transition: "transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease",
	_hover: {
		transform: "translateY(-4px) scale(1.03)",
		boxShadow: "0 8px 28px rgba(0,0,0,0.11)",
	},
});

// OGP画像がある場合は全面表示カード
const ogpCardStyles = css({
	position: "relative",
	overflow: "hidden",
	borderRadius: "18px",
	minHeight: "130px",
	textDecoration: "none",
	boxShadow: "0 3px 16px rgba(0,0,0,0.1)",
	transition: "transform 0.25s ease, box-shadow 0.25s ease",
	_hover: {
		transform: "translateY(-4px) scale(1.03)",
		boxShadow: "0 8px 28px rgba(0,0,0,0.18)",
	},
});
---

<!-- bigBottom: 下波を大きくしてAboutセクション（透過）との境界を強調 -->
<SectionBackground id="links" bigBottom>
	<div class={innerStyles}>
		<div class={containerStyles}>
			<h2 class={titleStyles}>リンク</h2>

			<!-- 自宅サーバーリンク（links.ts で isHomeServer: true のもの） -->
			{
				featured.map((link) => (
					<a
						href={link.url}
						class={featuredCardStyles}
						style={`border: 1px solid ${link.color}55`}
						target="_blank"
						rel="noopener noreferrer"
					>
						<div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
							<div
								style={`width: 56px; height: 56px; border-radius: 14px; background: ${link.color}; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden;`}
							>
								<LinkIcon icon={link.icon} color="white" size={32} ogpSrc={null} />
							</div>
							<div style="flex: 1;">
								<div style="display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
									<span
										style={`font-size: 1.3rem; font-weight: bold; color: ${link.color}; font-family: 'Zen Maru Gothic', sans-serif;`}
									>
										{link.label}
									</span>
									{link.isHomeServer && (
										<span
											style={`font-size: 0.72rem; font-weight: bold; background: ${link.color}; color: white; padding: 0.15rem 0.5rem; border-radius: 20px; letter-spacing: 0.04em;`}
										>
											自宅サーバー
										</span>
									)}
								</div>
								{link.description && (
									<div style="font-size: 0.9rem; color: #666;">{link.description}</div>
								)}
							</div>
						</div>
					</a>
				))
			}

			<!-- グリッドリンク（links.ts にエントリ追加で自動反映） -->
			<div class={gridStyles}>
				{
					others.map((link) => {
						const ogp = link.icon === "ogp" ? ogpImages[link.url] : null;
						if (ogp) {
							// OGP画像あり: 全面表示
							return (
								<a href={link.url} class={ogpCardStyles} target="_blank" rel="noopener noreferrer">
									<img
										src={ogp}
										alt={link.label}
										style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
									/>
									<span style="position:absolute;bottom:0;left:0;right:0;padding:0.4rem 0.6rem 0.6rem;font-size:0.85rem;font-weight:bold;color:white;background:linear-gradient(transparent,rgba(0,0,0,0.55));text-align:center;font-family:'Zen Maru Gothic',sans-serif;">
										{link.label}
									</span>
								</a>
							);
						}
						// 通常カード: アイコン＋ラベル
						return (
							<a
								href={link.url}
								class={cardStyles}
								target="_blank"
								rel="noopener noreferrer"
								style={`--card-color: ${link.color}`}
							>
								<div
									style={`width: 48px; height: 48px; border-radius: 12px; background: ${link.color}; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0;`}
								>
									<LinkIcon icon={link.icon} color="white" size={28} ogpSrc={null} />
								</div>
								<span
									style={`font-size: 0.95rem; font-weight: bold; color: #4a4a4a; font-family: 'Zen Maru Gothic', sans-serif; text-align: center;`}
								>
									{link.label}
								</span>
								{link.description && (
									<span style="font-size: 0.75rem; color: #888; text-align: center;">
										{link.description}
									</span>
								)}
							</a>
						);
					})
				}
			</div>
		</div>
	</div>
</SectionBackground>

<style>
	/* ホバー時にカードアクセントカラーで縁取り */
	a:hover {
		border-color: var(--card-color, rgba(200, 200, 200, 0.5)) !important;
	}
</style>
