---
import { css } from "../../styled-system/css";
---

<div
    class={css({
        position: "fixed",
        bottom: "5%",
        left: "5%",
        width: "60px",
        height: "40px",
        backgroundColor: "white",
        borderRadius: "0 0 30px 30px",
        border: "2px solid #e0e0e0",
        zIndex: 10,
        _before: {
            // Handle
            content: '""',
            position: "absolute",
            top: "5px",
            right: "-15px",
            width: "20px",
            height: "20px",
            borderRadius: "50%",
            border: "3px solid white",
        },
    })}
>
    <!-- Steam -->
    <div
        class={css({
            position: "absolute",
            top: "-30px",
            left: "10px",
            width: "8px",
            height: "30px",
            backgroundColor: "rgba(255, 255, 255, 0.5)",
            borderRadius: "10px",
            filter: "blur(3px)",
            animation: "steam 2s infinite ease-out",
        })}
    >
    </div>
    <div
        class={css({
            position: "absolute",
            top: "-20px",
            left: "30px",
            width: "8px",
            height: "25px",
            backgroundColor: "rgba(255, 255, 255, 0.5)",
            borderRadius: "10px",
            filter: "blur(3px)",
            animation: "steam 2.5s infinite ease-out 0.5s",
        })}
    >
    </div>
</div>
