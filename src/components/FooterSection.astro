---
import { css } from "../../styled-system/css";

const footerStyles = css({
	padding: "4rem 2rem",
	backgroundColor: "#3e3e3e", // Desk color
	color: "white",
	textAlign: "center",
	position: "relative",
	overflow: "hidden",
	backgroundImage: "radial-gradient(#4a4a4a 15%, transparent 16%)",
	backgroundSize: "20px 20px",
});

const stickersContainer = css({
	display: "flex",
	justifyContent: "center",
	gap: "3rem",
	flexWrap: "wrap",
	marginBottom: "4rem",
	maxWidth: "800px",
	margin: "0 auto 4rem auto",
});

const stickerLink = css({
	width: "100px",
	height: "100px",
	backgroundColor: "white",
	color: "#333",
	borderRadius: "10px",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	fontSize: "1.2rem",
	fontWeight: "bold",
	textDecoration: "none",
	boxShadow: "0 5px 10px rgba(0,0,0,0.3)",
	transition: "transform 0.2s ease",
	border: "4px solid white",
	_hover: {
		transform: "scale(1.1) rotate(0deg) !important", // Reset rotation on hover
		zIndex: 10,
	},
});

const copyrightStyles = css({
	fontSize: "0.9rem",
	opacity: 0.7,
	marginTop: "2rem",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	gap: "0.5rem",
});
---

<footer class={footerStyles}>
    <h2
        class={css({
            fontSize: "2rem",
            marginBottom: "3rem",
            fontFamily: '"Zen Maru Gothic"',
        })}
    >
        Links
    </h2>

    <div class={stickersContainer}>
        <a
            href="#"
            class={stickerLink}
            style="transform: rotate(-10deg); background-color: #1da1f2; color: white;"
        >
            Twitter
        </a>
        <a
            href="#"
            class={stickerLink}
            style="transform: rotate(5deg); background-color: #333; color: white;"
        >
            GitHub
        </a>
        <a
            href="#"
            class={stickerLink}
            style="transform: rotate(-5deg); background-color: #55acee; color: white;"
        >
            Bluesky
        </a>
        <a
            href="#"
            class={stickerLink}
            style="transform: rotate(15deg); background-color: #9146ff; color: white;"
        >
            Misskey
        </a>
    </div>

    <div class={copyrightStyles}>
        <span>&copy; 2026 Ieneko Youkan</span>
        <span class={css({ fontSize: "1.2rem" })}>🐈💤</span>
    </div>
</footer>
