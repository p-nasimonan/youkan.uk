---
import "../index.css";
import { css } from "@styled/css";

const { title = "Ieneko Youkan's Room" } = Astro.props;

const videoBgStyles = css({
	position: "fixed",
	top: 0,
	left: 0,
	width: "100%",
	height: "100%",
	objectFit: "cover",
	zIndex: -2,
	opacity: 0.85,
});


const wrapperStyles = css({
	position: "relative",
	minHeight: "100vh",
	overflow: "hidden",
});
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Fixed Video Background (shared across all sections) -->
		<video class={videoBgStyles} autoplay loop muted playsinline poster="/hero/videomock.png">
			<source src="/hero.webm" type="video/webm" />
		</video>
		<div class={wrapperStyles}>
			<slot />
		</div>
	</body>
</html>

<script>
	// Scroll-in animation: section[data-animate] enters from below when visible
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add("is-visible");
				}
			}
		},
		{ threshold: 0.05 },
	);

	document.querySelectorAll("[data-animate]").forEach((el) => {
		observer.observe(el);
	});
</script>

<!-- Global animation styles: managed here to avoid Astro scoping issues -->
<style is:global>
	/* ===== Section scroll-in (opacity only — no translateY to avoid wave gap) ===== */
	[data-animate] {
		opacity: 0;
		transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1);
	}
	[data-animate].is-visible {
		opacity: 1;
	}

	/* ===== Wave divider (frill border between sections) ===== */
	@keyframes waveScroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}

	.wave-wrapper {
		position: absolute;
		top: -1px;
		left: 0;
		/* 200% wide: holds 2 copies of the SVG for seamless loop */
		width: 200%;
		height: 64px;
		z-index: 5;
		pointer-events: none;
		animation: waveScroll 10s linear infinite;
	}

	.wave-svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	/* HeroSection bottom wave sits at the bottom, not top */
	.wave-wrapper--bottom {
		top: auto;
		bottom: -1px;
		/* Flip vertically: the wave "pours down" into the next section */
		transform-origin: center;
	}
	/* We still need waveScroll on bottom wrapper, handled inline */

	/* Big variant for waves around transparent sections */
	.wave-wrapper--big {
		height: 128px;
	}

	/* Frill stroke line animates slightly offset from the fill wave */
	.wave-frill-line {
		animation-duration: 13s;
		z-index: 6;
	}
	.wave-wrapper--big.wave-frill-line {
		animation-duration: 17s;
	}
</style>
