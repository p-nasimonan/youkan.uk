---
import "../index.css";
import { css } from "@styled/css";

const { title = "Ieneko Youkan's Room" } = Astro.props;

const videoBgStyles = css({
	position: "fixed",
	top: 0,
	left: 0,
	width: "100%",
	height: "100%",
	objectFit: "cover",
	zIndex: -2,
	opacity: 0.85,
});


const wrapperStyles = css({
	position: "relative",
	minHeight: "100vh",
	overflow: "hidden",
});
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- 固定動画背景（全セクション共通） -->
		<video class={videoBgStyles} autoplay loop muted playsinline poster="/hero/videomock.png">
			<source src="/hero.webm" type="video/webm" />
		</video>
		<div class={wrapperStyles}>
			<slot />
		</div>
	</body>
</html>

<script>
	// スクロールアニメーション: [data-animate] 要素が画面内に入ったらフェードイン
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add("is-visible");
				}
			}
		},
		{ threshold: 0.05 },
	);

	document.querySelectorAll("[data-animate]").forEach((el) => {
		observer.observe(el);
	});
</script>

<!-- グローバルアニメーションスタイル（Astro のスコープを避けるため is:global） -->
<style is:global>
	/* ===== セクションスクロールアニメーション =====
	   波はセクション内部の absolute 要素なので translateY と一緒に動き、分離しない */
	[data-animate] {
		opacity: 0;
		transform: translateY(48px);
		transition:
			opacity 1.1s cubic-bezier(0.16, 1, 0.3, 1),
			transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	[data-animate].is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* ===== フリル波アニメーション（SectionBackground.astro から参照） ===== */
	@keyframes waveScroll {
		0%   { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
</style>
