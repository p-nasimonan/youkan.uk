---
import type { IconType } from "@consts/links";

interface Props {
	icon: IconType;
	color?: string;
	size?: number;
	ogpSrc?: string | null;
}

const { icon, color = "white", size = 28, ogpSrc = null } = Astro.props;
---

{
	ogpSrc ? (
		<img
			src={ogpSrc}
			width={size}
			height={size}
			alt=""
			style="object-fit: cover; border-radius: 4px; display: block;"
		/>
	) : icon === "twitter" ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill={color}>
			<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
		</svg>
	) : icon === "github" ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill={color}>
			<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
		</svg>
	) : icon === "bluesky" ? (
		<svg width={size} height={size} viewBox="0 0 600 530" fill={color}>
			<path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.862 590 68.825c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.38-3.69-10.832-3.708-7.896-.017-2.936-1.193.516-3.707 7.896-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.449-163.25-81.433C20.15 217.615 10 86.541 10 68.825c0-88.687 77.742-60.816 125.72-24.795z" />
		</svg>
	) : icon === "misskey" ? (
		<img
			src="https://mi.youkan.uk/favicon.ico"
			width={size}
			height={size}
			alt="Misskey"
			style="object-fit: contain; display: block;"
		/>
	) : null
}
