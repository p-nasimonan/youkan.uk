---

---

<img id="cursor-image" src="/cusor/default.png" alt="cursor" class="cursor-image" />

<script>
    const cursorImg = document.getElementById("cursor-image") as HTMLImageElement;

    if (cursorImg) {
        let mouseX = 0;
        let mouseY = 0;
        let cursorX = 0;
        let cursorY = 0;

        // Hide default cursor
        document.body.style.cursor = "none";

        document.addEventListener("mousemove", (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
        });

        // Smooth follow animation
        function animate() {
            cursorX += (mouseX - cursorX) * 0.9;
            cursorY += (mouseY - cursorY) * 0.9;
            cursorImg.style.transform = `translate(${cursorX}px, ${cursorY}px)`;
            requestAnimationFrame(animate);
        }
        animate();

        // Click burst
        document.addEventListener("click", (e) => {
            const burst = document.createElement("div");
            burst.classList.add("star-burst");
            burst.style.left = `${e.clientX}px`;
            burst.style.top = `${e.clientY}px`;
            document.body.appendChild(burst);
            setTimeout(() => burst.remove(), 500);
        });

        // Hover on links/buttons: change to pointer image
        document.addEventListener("mouseover", (e) => {
            if (
                e.target instanceof Element &&
                (e.target.closest("a") || e.target.closest("button"))
            ) {
                cursorImg.src = "/cusor/pointer.png";
                cursorImg.classList.add("hover");
            }
        });
        document.addEventListener("mouseout", (e) => {
            if (
                e.target instanceof Element &&
                (e.target.closest("a") || e.target.closest("button"))
            ) {
                cursorImg.src = "/cusor/default.png";
                cursorImg.classList.remove("hover");
            }
        });
    }
</script>

<style>
    .cursor-image {
        position: fixed;
        top: 0;
        left: 0;
        width: 48px;
        height: 48px;
        pointer-events: none;
        z-index: 10000;
        margin-top: -24px;
        margin-left: -24px;
        transition: transform 0.1s ease;
    }

    .cursor-image.hover {
        transform: scale(1.2);
    }

    :global(.star-burst) {
        position: fixed;
        width: 40px;
        height: 40px;
        background: radial-gradient(
            circle,
            rgba(255, 107, 107, 1) 0%,
            rgba(255, 255, 255, 0) 70%
        );
        transform: translate(-50%, -50%);
        pointer-events: none;
        animation: pop 0.5s ease-out forwards;
        z-index: 9998;
    }

    @keyframes pop {
        0% {
            transform: translate(-50%, -50%) scale(0.5);
            opacity: 1;
        }
        100% {
            transform: translate(-50%, -50%) scale(2);
            opacity: 0;
        }
    }
</style>
