---
import { getImage } from "astro:assets";
import { css } from "@styled/css";
import defaultSrc from "../assets/cusor/default.png";
import pointerSrc from "../assets/cusor/pointer.png";

const defaultImg = await getImage({ src: defaultSrc, format: "webp", width: 48, height: 48 });
const pointerImg = await getImage({ src: pointerSrc, format: "webp", width: 48, height: 48 });

const cursorClass = css({
	position: "fixed",
	top: 0,
	left: 0,
	width: "48px",
	height: "48px",
	pointerEvents: "none",
	zIndex: 10000,
	marginTop: "-24px",
	marginLeft: "-24px",
	userSelect: "none",
});
---

<img
	id="cursor-image"
	src={defaultImg.src}
	alt=""
	class={cursorClass}
	data-default={defaultImg.src}
	data-pointer={pointerImg.src}
/>

<script>
	const cursorImg = document.getElementById("cursor-image") as HTMLImageElement;
	if (!cursorImg) throw new Error("cursor-image not found");

	const defaultSrc = cursorImg.dataset.default!;
	const pointerSrc = cursorImg.dataset.pointer!;

	let mouseX = 0;
	let mouseY = 0;
	let cursorX = 0;
	let cursorY = 0;
	let isHover = false;

	document.addEventListener("mousemove", (e) => {
		mouseX = e.clientX;
		mouseY = e.clientY;
	});

	(function animate() {
		cursorX += (mouseX - cursorX) * 0.9;
		cursorY += (mouseY - cursorY) * 0.9;
		const scale = isHover ? 1.2 : 1;
		cursorImg.style.transform = `translate(${cursorX}px, ${cursorY}px) scale(${scale})`;
		requestAnimationFrame(animate);
	})();

	document.addEventListener("click", (e) => {
		const burst = document.createElement("div");
		burst.className = "star-burst";
		burst.style.left = `${e.clientX}px`;
		burst.style.top = `${e.clientY}px`;
		document.body.appendChild(burst);
		burst.addEventListener("animationend", () => burst.remove(), { once: true });
	});

	document.addEventListener("mouseover", (e) => {
		if (e.target instanceof Element && (e.target.closest("a") || e.target.closest("button"))) {
			cursorImg.src = pointerSrc;
			isHover = true;
		}
	});
	document.addEventListener("mouseout", (e) => {
		if (e.target instanceof Element && (e.target.closest("a") || e.target.closest("button"))) {
			cursorImg.src = defaultSrc;
			isHover = false;
		}
	});
</script>
