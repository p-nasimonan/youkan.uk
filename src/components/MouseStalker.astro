---

<div id="stalker-dot" class="stalker-dot"></div>
<div id="stalker-ring" class="stalker-ring"></div>

<script>
    const dot = document.getElementById("stalker-dot");
    const ring = document.getElementById("stalker-ring");

    if (dot && ring) {
        let mouseX = 0;
        let mouseY = 0;
        let ringX = 0;
        let ringY = 0;

        document.addEventListener("mousemove", (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            // dot follows exactly
            dot.style.transform = `translate(${mouseX}px, ${mouseY}px)`;
        });

        // Ring follows with smooth delay
        function animate() {
            ringX += (mouseX - ringX) * 0.12;
            ringY += (mouseY - ringY) * 0.12;
            ring.style.transform = `translate(${ringX}px, ${ringY}px)`;
            requestAnimationFrame(animate);
        }
        animate();

        // Click burst
        document.addEventListener("click", (e) => {
            const burst = document.createElement("div");
            burst.classList.add("star-burst");
            burst.style.left = `${e.clientX}px`;
            burst.style.top = `${e.clientY}px`;
            document.body.appendChild(burst);
            setTimeout(() => burst.remove(), 500);
        });

        // Hover on links/buttons: enlarge ring
        document.addEventListener("mouseover", (e) => {
            if (
                e.target instanceof Element &&
                (e.target.closest("a") || e.target.closest("button"))
            ) {
                ring.classList.add("hover");
            }
        });
        document.addEventListener("mouseout", (e) => {
            if (
                e.target instanceof Element &&
                (e.target.closest("a") || e.target.closest("button"))
            ) {
                ring.classList.remove("hover");
            }
        });
    }
</script>

<style>
    .stalker-dot {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        background-color: #ff6b6b;
        border-radius: 50%;
        pointer-events: none;
        z-index: 10000;
        margin-top: -4px;
        margin-left: -4px;
        box-shadow: 0 0 6px 2px rgba(255, 107, 107, 0.7);
    }

    .stalker-ring {
        position: fixed;
        top: 0;
        left: 0;
        width: 36px;
        height: 36px;
        border: 2.5px solid rgba(255, 107, 107, 0.85);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        margin-top: -18px;
        margin-left: -18px;
        box-shadow: 0 0 8px rgba(255, 107, 107, 0.4);
        transition:
            width 0.2s ease,
            height 0.2s ease,
            margin 0.2s ease;
    }

    .stalker-ring.hover {
        width: 56px;
        height: 56px;
        margin-top: -28px;
        margin-left: -28px;
    }

    :global(.star-burst) {
        position: fixed;
        width: 40px;
        height: 40px;
        background: radial-gradient(
            circle,
            rgba(255, 107, 107, 1) 0%,
            rgba(255, 255, 255, 0) 70%
        );
        transform: translate(-50%, -50%);
        pointer-events: none;
        animation: pop 0.5s ease-out forwards;
        z-index: 9998;
    }

    @keyframes pop {
        0% {
            transform: translate(-50%, -50%) scale(0.5);
            opacity: 1;
        }
        100% {
            transform: translate(-50%, -50%) scale(2);
            opacity: 0;
        }
    }
</style>
