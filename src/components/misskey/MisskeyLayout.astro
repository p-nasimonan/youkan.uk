---
import GlobalLayout from "../../layouts/Layout.astro";
import MouseStalker from "../MouseStalker.astro";
import { css } from "@styled/css";

interface Props {
	title?: string;
	description?: string;
	hideNavLinks?: boolean;
	frontmatter?: {
		title: string;
		description?: string;
		hideNavLinks?: boolean;
	};
}

const title = Astro.props.title || Astro.props.frontmatter?.title || "Misskey";
const description = Astro.props.description || Astro.props.frontmatter?.description;
const hideNavLinks = Astro.props.hideNavLinks || Astro.props.frontmatter?.hideNavLinks || false;

// 現在のページのパスを取得して末尾の / を除外
const currentPath = Astro.url.pathname.replace(/\/$/, "");

// リンク集の定義
const allLinks = [
	{ name: "Misskeyについて", path: "/misskey" },
	{ name: "利用規約", path: "/misskey/terms" },
	{ name: "プライバシーポリシー", path: "/misskey/privacy" },
	{ name: "お問い合わせ", path: "/misskey/contact" },
];

// 現在のページ「以外」のリンクを抽出
const otherLinks = allLinks.filter(link => link.path !== currentPath);

const containerStyle = css({
	maxWidth: "800px",
	margin: "4rem auto",
	backgroundColor: "rgba(255, 255, 255, 0.92)",
	borderRadius: "24px",
	boxShadow: "0 8px 32px rgba(0, 0, 0, 0.1)",
	overflow: "hidden",
	backdropFilter: "blur(10px)",
});

const bannerContainerStyle = css({
	position: "relative",
	display: "block",
	textDecoration: "none !important",
	"& .overlay": {
		position: "absolute",
		bottom: 0,
		left: 0,
		right: 0,
		padding: "2rem",
		background: "linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%)",
		display: "flex",
		alignItems: "center",
		gap: "1.2rem",
		color: "white",
	},
	"& .external-icon": {
		opacity: 0,
		color: "white",
		transition: "all 0.3s ease",
		transform: "translateX(-10px) translateY(10px)",
	},
	"&:hover .external-icon": {
		opacity: 1,
		transform: "translateX(0) translateY(0)",
	},
});

const bannerImgStyle = css({
	width: "100%",
	height: "260px",
	objectFit: "cover",
	display: "block",
});

const contentStyle = css({
	padding: "3rem 4rem",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	color: "#444",
	md: {
		padding: "2rem 2rem",
	},
	// --- Markdown要素・共通装飾のスタイル（子孫セレクタでPanda CSSに統合） ---
	"& h2": {
		fontSize: "1.5rem",
		color: "#555",
		marginTop: "2.5rem",
		marginBottom: "1rem",
		borderBottom: "1px solid #eee",
		paddingBottom: "0.5rem",
	},
	"& h3": {
		fontSize: "1.25rem",
		color: "#555",
		marginTop: "2rem",
		marginBottom: "0.8rem",
	},
	"& p": {
		lineHeight: "1.8",
		marginBottom: "1.5rem",
	},
	"& a": {
		color: "#5c93e6",
		textDecoration: "none",
		transition: "color 0.2s",
		_hover: {
			color: "#3b71c7",
			textDecoration: "underline",
		},
	},
	"& ul, & ol": {
		marginBottom: "1.5rem",
		paddingLeft: "1.5rem",
		lineHeight: "1.8",
	},
	"& li": {
		marginBottom: "0.5rem",
	},
	"& .nav-links": {
		display: "flex",
		flexWrap: "wrap",
		gap: "1rem",
		marginTop: "3rem",
		paddingTop: "2rem",
		borderTop: "2px dashed #e0e0e0",
	},
	"& .button-link": {
		display: "inline-block",
		padding: "0.8rem 1.5rem",
		background: "#f0f7ff",
		color: "#5c93e6",
		borderRadius: "12px",
		fontWeight: "bold",
		textDecoration: "none",
		transition: "all 0.2s ease",
		_hover: {
			background: "#5c93e6",
			color: "white",
			textDecoration: "none",
			transform: "translateY(-2px)",
		},
	},
});

const overlayIconStyle = css({
	width: "72px",
	height: "72px",
	borderRadius: "16px",
	objectFit: "cover",
	boxShadow: "0 4px 10px rgba(0,0,0,0.4)",
	border: "2px solid rgba(255, 255, 255, 0.8)",
});

const overlayTitleStyle = css({
	fontSize: "1.8rem",
	fontWeight: "bold",
	textShadow: "0 2px 4px rgba(0,0,0,0.6)",
	margin: 0,
});

const pageTitleStyle = css({
	fontSize: "1.8rem",
	fontWeight: "bold",
	color: "#4a4a4a",
});

const backHomeBtnStyle = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "0.5rem",
	padding: "0.5rem 1rem",
	backgroundColor: "#f8fafc",
	color: "#64748b",
	borderRadius: "20px",
	textDecoration: "none !important",
	fontWeight: "bold",
	fontSize: "0.9rem",
	transition: "all 0.2s ease",
	border: "1px solid #e2e8f0",
	"&:hover": {
		backgroundColor: "#f1f5f9",
		color: "#334155",
		transform: "translateY(-2px)",
	}
});
---

<GlobalLayout title={`Misskey - ${title}`} description={description}>
	<MouseStalker />
	<div class={containerStyle} data-animate>
		<a href="https://mi.youkan.uk/" target="_blank" rel="noopener noreferrer" class={bannerContainerStyle}>
			<img src="/misskey/assets/banner.png" alt="Misskey Banner" class={bannerImgStyle} />
			<div class="overlay">
				<img src="/misskey/assets/icon.png" alt="Misskey Icon" class={overlayIconStyle} />
				<div style="display: flex; align-items: center; gap: 0.5rem;">
					<h2 class={overlayTitleStyle}>ようかんのみすきー</h2>
					<svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</div>
			</div>
		</a>
		<div class={contentStyle}>
			<div style="display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px dashed #e0e0e0; padding-bottom: 1rem; margin-bottom: 1.5rem;">
				<h1 class={pageTitleStyle}>{title}</h1>
				<a href="/" class={backHomeBtnStyle}>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
						<polyline points="9 22 9 12 15 12 15 22"></polyline>
					</svg>
					youkan.uk
				</a>
			</div>
			<slot />

			{!hideNavLinks && otherLinks.length > 0 && (
				<div class="nav-links">
					{otherLinks.map(link => (
						<a href={link.path} class="button-link">{link.name}</a>
					))}
				</div>
			)}
		</div>
	</div>
</GlobalLayout>

