---
import { css } from "@styled/css";

interface Series {
	label: string;
	data: number[];
	color: string;
}

interface Props {
	series: Series[];
	title: string;
	unit?: string;
	spanLabel?: string;
}

const { series, title, unit = "件", spanLabel = "時間" } = Astro.props;

const n = series[0]?.data.length ?? 0;

const VIEWBOX_W = 560;
const VIEWBOX_H = 80;
const gap       = 2;
const barW      = (VIEWBOX_W - gap * (n - 1)) / n;

const totals = Array.from({ length: n }, (_, i) =>
	series.reduce((s, ser) => s + (ser.data[i] ?? 0), 0),
);
const maxVal   = Math.max(...totals, 1);
const totalAll = totals.reduce((s, v) => s + v, 0);

type RectInfo = { x: number; y: number; w: number; h: number; v: number; color: string; label: string };
const rects: RectInfo[] = [];
for (let i = 0; i < n; i++) {
	let cumH = 0;
	for (const ser of series) {
		const v = ser.data[i] ?? 0;
		const h = Math.max((v / maxVal) * VIEWBOX_H, v > 0 ? 1 : 0);
		const y = VIEWBOX_H - cumH - h;
		rects.push({ x: i * (barW + gap), y, w: barW, h, v, color: ser.color, label: ser.label });
		cumH += h;
	}
}

const fmt = (n: number) => {
	if (n >= 10000) return `${Math.round(n / 1000)}k`;
	if (n >= 1000)  return `${(n / 1000).toFixed(1).replace(/\.0$/, "")}k`;
	return String(Math.round(n));
};

const yTicks = [maxVal, maxVal / 2, 0].filter((v, i, arr) =>
	arr.findIndex(u => fmt(u) === fmt(v)) === i,
);

const wrapStyle     = css({ marginBottom: "1.8rem" });
const headerStyle   = css({ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: "0.4rem" });
const labelStyle    = css({ fontSize: "0.85rem", fontWeight: "bold", color: "#555" });
const totalStyle    = css({ fontSize: "0.8rem", color: "#888" });
const chartRowStyle = css({ display: "flex", gap: "4px", alignItems: "stretch" });
const yAxisStyle    = css({
	width: "32px",
	flexShrink: 0,
	display: "flex",
	flexDirection: "column",
	justifyContent: "space-between",
	paddingBottom: "18px",
	alignItems: "flex-end",
});
const yTickStyle    = css({ fontSize: "0.6rem", color: "#bbb", lineHeight: 1 });
const svgWrapStyle  = css({ flex: 1, overflow: "hidden", borderRadius: "6px", background: "rgba(0,0,0,0.02)" });
const xAxisStyle    = css({ display: "flex", justifyContent: "space-between", fontSize: "0.6rem", color: "#bbb", padding: "2px 0" });
const legendStyle   = css({ display: "flex", flexWrap: "wrap", gap: "0.6rem", marginTop: "0.4rem", paddingLeft: "36px" });
const legendItemStyle = css({ display: "flex", alignItems: "center", gap: "0.3rem", fontSize: "0.7rem", color: "#777" });
---

<div class={wrapStyle}>
	<div class={headerStyle}>
		<span class={labelStyle}>{title}</span>
		<span class={totalStyle}>合計 {totalAll.toLocaleString()}{unit} / {n}{spanLabel}</span>
	</div>
	<div class={chartRowStyle}>
		<!-- Y軸ラベル -->
		<div class={yAxisStyle}>
			{yTicks.map(v => <span class={yTickStyle}>{fmt(v)}</span>)}
		</div>
		<!-- グラフ本体 -->
		<div class={svgWrapStyle}>
			<svg
				viewBox={`0 0 ${VIEWBOX_W} ${VIEWBOX_H}`}
				preserveAspectRatio="none"
				width="100%"
				height="60"
				aria-label={title}
				role="img"
			>
				<line x1="0" y1="0"  x2={VIEWBOX_W} y2="0"  stroke="#e5e7eb" stroke-width="1" />
				<line x1="0" y1="40" x2={VIEWBOX_W} y2="40" stroke="#e5e7eb" stroke-width="1" />

				{rects.map(({ x, y, w, h, v, color, label }) => (
					<rect x={x} y={y} width={w} height={h} rx="1" fill={color} opacity="0.85">
						<title>{label}: {v}{unit}</title>
					</rect>
				))}
			</svg>
			<div class={xAxisStyle}>
				<span>{n}{spanLabel}前</span>
				<span>今</span>
			</div>
		</div>
	</div>
	<!-- 凡例 -->
	<div class={legendStyle}>
		{series.map(ser => (
			<div class={legendItemStyle}>
				<span style={`display:inline-block;width:10px;height:10px;border-radius:2px;background:${ser.color};`} />
				{ser.label}
			</div>
		))}
	</div>
</div>
