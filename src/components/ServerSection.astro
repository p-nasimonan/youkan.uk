---
import { css } from "../../styled-system/css";

const sectionStyles = css({
	minHeight: "100vh",
	position: "relative",
	display: "flex",
	alignItems: "center",
	justifyContent: "center",
	overflow: "hidden",
	backgroundColor: "#222", // Darker background for server room feel
	color: "white",
});

const backgroundOverlay = css({
	position: "absolute",
	top: 0,
	left: 0,
	width: "100%",
	height: "100%",
	backgroundImage: "linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7))", // Darken the image
	zIndex: 1,
});

const container = css({
	position: "relative",
	zIndex: 2,
	maxWidth: "1200px",
	width: "100%",
	padding: "2rem",
	textAlign: "center",
});

const titleStyles = css({
	fontFamily: '"Zen Maru Gothic", sans-serif',
	fontSize: "3rem",
	marginBottom: "3rem",
	textShadow: "0 0 10px rgba(255,255,255,0.5)",
});

const serverRackStyles = css({
	position: "relative",
	width: "80%",
	maxWidth: "600px",
	margin: "0 auto",
	aspectRatio: "3/5",
	border: "2px solid #555",
	backgroundColor: "#111",
	borderRadius: "10px",
	boxShadow: "0 0 30px rgba(0, 255, 0, 0.1)",
	backgroundImage:
		"repeating-linear-gradient(0deg, #1a1a1a, #1a1a1a 19px, #333 20px)",
});

const tooltipTrigger = css({
	position: "absolute",
	width: "20px",
	height: "20px",
	backgroundColor: "rgba(0, 255, 0, 0.5)",
	borderRadius: "50%",
	cursor: "help",
	animation: "pulse 2s infinite",
	_hover: {
		backgroundColor: "rgba(0, 255, 0, 1)",
		scale: 1.2,
		"& .tooltip": {
			opacity: 1,
			visibility: "visible",
			transform: "translate(-50%, -120%)",
		},
	},
});

const tooltipStyles = css({
	position: "absolute",
	bottom: "100%",
	left: "50%",
	transform: "translate(-50%, -100%)",
	backgroundColor: "white",
	color: "#333",
	padding: "0.5rem 1rem",
	borderRadius: "5px",
	fontSize: "0.9rem",
	whiteSpace: "nowrap",
	opacity: 0,
	visibility: "hidden",
	transition: "all 0.3s ease",
	boxShadow: "0 4px 10px rgba(0,0,0,0.2)",
	pointerEvents: "none",
	fontWeight: "bold",
	"&::after": {
		content: '""',
		position: "absolute",
		top: "100%",
		left: "50%",
		marginLeft: "-5px",
		borderWidth: "5px",
		borderStyle: "solid",
		borderColor: "white transparent transparent transparent",
	},
});

// Positioning specific triggers
const cpuPos = css({ top: "20%", left: "30%" });
const ramPos = css({ top: "40%", right: "30%" });
const osPos = css({ bottom: "20%", left: "40%" });
---

<section class={sectionStyles}>
    <div class={backgroundOverlay}></div>
    <!-- Placeholder text for background image suggestion -->
    <div
        class={css({
            position: "absolute",
            zIndex: 0,
            color: "#444",
            fontSize: "10rem",
            fontWeight: "bold",
            opacity: 0.1,
        })}
    >
        SERVER ROOM
    </div>

    <div class={container}>
        <h2 class={titleStyles}>My Secret Base</h2>
        <p
            class={css({
                marginBottom: "2rem",
                fontSize: "1.2rem",
                color: "#ccc",
            })}
        >
            Hover over the lights!
        </p>

        <div class={serverRackStyles}>
            <!-- CPU Trigger -->
            <div class={`${tooltipTrigger} ${cpuPos}`}>
                <div class={`${tooltipStyles} tooltip`}>
                    🔥 CPU: Ryzen 9 5950X
                </div>
            </div>

            <!-- RAM Trigger -->
            <div class={`${tooltipTrigger} ${ramPos}`}>
                <div class={`${tooltipStyles} tooltip`}>🧠 RAM: 64GB DDR4</div>
            </div>

            <!-- OS Trigger -->
            <div class={`${tooltipTrigger} ${osPos}`}>
                <div class={`${tooltipStyles} tooltip`}>
                    🐧 OS: Ubuntu 22.04 LTS<br />Kernel: 5.15.0
                </div>
            </div>

            <!-- Handwritten style arrows (CSS shapes for simplicity) -->
            <div
                class={css({
                    position: "absolute",
                    top: "22%",
                    left: "10%",
                    color: "white",
                    transform: "rotate(-20deg)",
                    fontFamily: '"Zen Maru Gothic"',
                })}
            >
                Fast! →
            </div>
        </div>
    </div>
</section>
