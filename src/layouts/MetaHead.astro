---
interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title       = "Ieneko Youkan's Room",
	description = "家猫ようかんのホームページ。自宅サーバー・リンク・作品置き場。",
	ogImage     = "/hero/videomock.png",
} = Astro.props;

const origin      = Astro.url.origin;
const canonicalUrl = `${origin}${Astro.url.pathname}`;
const ogImageUrl   = `${origin}${ogImage}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Primary meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type"        content="website" />
<meta property="og:locale"      content="ja_JP" />
<meta property="og:site_name"   content="Ieneko Youkan's Room" />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:url"         content={canonicalUrl} />
<meta property="og:image"       content={ogImageUrl} />
<meta property="og:image:width"  content="1280" />
<meta property="og:image:height" content="720" />
<meta property="og:image:alt"    content={title} />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content="@youkan0124" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImageUrl} />
