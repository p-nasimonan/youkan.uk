---
import "../index.css";
import { css } from "@styled/css";
import { getImage } from "astro:assets";
import videomockSrc from "../assets/hero/videomock.png";
import MetaHead from "./MetaHead.astro";

const poster = await getImage({ src: videomockSrc, format: "webp", quality: 85 });

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
// OGP 未指定時は処理済みアセット URL を使用（public/ 不要）
const defaultOgImage = Astro.url.origin + poster.src;

const videoBgStyles = css({
	position: "fixed",
	top: 0,
	left: 0,
	width: "100%",
	height: "100%",
	objectFit: "cover",
	zIndex: -2,
	opacity: 0.85,
});

const wrapperStyles = css({
	position: "relative",
	minHeight: "100vh",
});
---

<html lang="ja">
	<head>
		<MetaHead title={title} description={description} ogImage={ogImage ?? defaultOgImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- フォント: JS でノンブロッキング挿入（レンダリングブロック解消）-->
		<script is:inline>
			var _fl = document.createElement("link");
			_fl.rel = "stylesheet";
			_fl.href = "https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700&display=swap";
			document.head.appendChild(_fl);
		</script>
	</head>
	<body>
		<!-- 固定動画背景（全セクション共通） -->
		<video class={videoBgStyles} autoplay loop muted playsinline poster={poster.src}>
			<source src="/hero.webm" type="video/webm" />
		</video>
		<div class={wrapperStyles}>
			<slot />
		</div>
	</body>
</html>

<script>
	// ===== スクロールフェードイン =====
	// [data-animate] 要素が画面内に入ったら is-visible を付与（1回のみ）
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add("is-visible");
					observer.unobserve(entry.target);
				}
			}
		},
		{ threshold: 0.08 },
	);
	document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));

	// ===== カスタムカーソル（水紋トレイル） =====
	// cursor: none（index.css）に合わせて、ドット＋水紋を JS で管理する
	const dot = document.createElement("div");
	dot.id = "cursor-dot";
	document.body.appendChild(dot);

	// 最後の水紋生成時刻（スロットル用）
	let lastRipple = 0;

	function spawnRipple(x: number, y: number) {
		const now = Date.now();
		if (now - lastRipple < 65) return; // 約15fps でスポーン
		lastRipple = now;
		const el = document.createElement("div");
		el.className = "cursor-ripple";
		el.style.left = `${x}px`;
		el.style.top  = `${y}px`;
		document.body.appendChild(el);
		// アニメーション終了後に削除
		el.addEventListener("animationend", () => el.remove(), { once: true });
	}

	document.addEventListener("mousemove", (e) => {
		dot.style.translate = `${e.clientX}px ${e.clientY}px`;
		spawnRipple(e.clientX, e.clientY);
	});

	// クリック時にリング状のバーストを表示
	document.addEventListener("click", (e) => {
		const burst = document.createElement("div");
		burst.className = "cursor-burst";
		burst.style.left = `${e.clientX}px`;
		burst.style.top  = `${e.clientY}px`;
		document.body.appendChild(burst);
		burst.addEventListener("animationend", () => burst.remove(), { once: true });
	});

	// ===== スムーズスクロール（Lenis） =====
	// Layout.astro に完全集約 — セクション側の変更不要
	// duration: 大きいほどゆっくり (0.8〜1.6 推奨)
	import Lenis from "lenis";

	const lenis = new Lenis({
		duration: 1.2,
		easing: (t: number) => Math.min(1, 1.001 - 2 ** (-10 * t)), // expo 的な減衰
		touchMultiplier: 2,
	});

	function raf(time: number) {
		lenis.raf(time);
		requestAnimationFrame(raf);
	}
	requestAnimationFrame(raf);

	// ハッシュリンク（/#links など）→ Lenis に委譲
	document.addEventListener("click", (e) => {
		const a = (e.target as Element).closest("a");
		if (!a) return;
		const href = a.getAttribute("href") ?? "";
		const hash = href.startsWith("/#") ? href.slice(2)
			       : href.startsWith("#")  ? href.slice(1)
			       : null;
		if (!hash) return;
		const el = document.getElementById(hash);
		if (!el) return;
		e.preventDefault();
		lenis.scrollTo(el, { offset: 0 });
	});
</script>

<!-- グローバルアニメーションスタイル（Astro のスコープを避けるため is:global） -->
<style is:global>
	/* ===== セクションコンテンツのフロートイン =====
	   波は <section> 要素側（アニメーションなし）に固定されるため分離しない。
	   [data-animate] はセクション内部の <div> に付与する。 */
	[data-animate] {
		opacity: 0;
		transform: translateY(52px);
		will-change: transform, opacity;
		transition:
			opacity 1.0s cubic-bezier(0.16, 1, 0.3, 1),
			transform 1.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	[data-animate].is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* ===== フリル波アニメーション =====
	   background-position-x を1アーチ分シフトしてシームレスループ。
	   通常アーチ: 240px、大アーチ: 360px */
	@keyframes waveNorm {
		from { background-position: 0 0; }
		to   { background-position: -240px 0; }
	}
	@keyframes waveBig {
		from { background-position: 0 0; }
		to   { background-position: -360px 0; }
	}

	/* ===== カスタムカーソル ===== */
	#cursor-dot {
		position: fixed;
		top: 0;
		left: 0;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: rgba(125, 211, 252, 0.9);
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 9999;
		mix-blend-mode: multiply;
	}

	/* 水紋トレイル: mousemove のたびに JS で生成・削除 */
	.cursor-ripple {
		position: fixed;
		pointer-events: none;
		z-index: 9997;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: rgba(125, 211, 252, 0.55);
		animation: waterDrop 0.75s ease-out forwards;
	}

	@keyframes waterDrop {
		0%   { transform: translate(-50%, -50%) scale(0.2); opacity: 0.6; }
		100% { transform: translate(-50%, -50%) scale(4.0); opacity: 0;   }
	}

	/* クリックバースト */
	.cursor-burst {
		position: fixed;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		border: 2px solid rgba(125, 211, 252, 0.75);
		pointer-events: none;
		z-index: 9998;
		animation: burstOut 0.45s ease-out forwards;
	}
	@keyframes burstOut {
		0%   { transform: translate(-50%, -50%) scale(0.2); opacity: 1; }
		100% { transform: translate(-50%, -50%) scale(2.5); opacity: 0; }
	}

	/* MouseStalker クリックバースト */
	.star-burst {
		position: fixed;
		width: 40px;
		height: 40px;
		background: radial-gradient(circle, rgba(255, 107, 107, 1) 0%, rgba(255, 255, 255, 0) 70%);
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 9998;
		animation: starPop 0.5s ease-out forwards;
	}
	@keyframes starPop {
		0%   { transform: translate(-50%, -50%) scale(0.5); opacity: 1; }
		100% { transform: translate(-50%, -50%) scale(2);   opacity: 0; }
	}
</style>
