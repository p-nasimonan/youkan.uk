---
import MisskeyLayout from "../../components/misskey/MisskeyLayout.astro";
import { css } from "@styled/css";

let isOnline = false;
try {
	const res = await fetch("https://mi.youkan.uk/api/meta", {
		method: "POST",
		headers: {
			"Content-Type": "application/json",
		},
		body: JSON.stringify({ detail: false }),
	});
	if (res.ok) {
		isOnline = true;
	}
} catch (e) {
	console.error("Failed to fetch Misskey meta API:", e);
}

const statusContainer = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "0.8rem",
	padding: "0.8rem 1.2rem",
	backgroundColor: "rgba(240, 240, 240, 0.8)",
	borderRadius: "12px",
	marginBottom: "2rem",
	fontWeight: "bold",
	fontSize: "0.95rem",
	boxShadow: "inset 0 2px 4px rgba(0,0,0,0.02)",
});

const statusDot = css({
	width: "12px",
	height: "12px",
	borderRadius: "50%",
});
---

<MisskeyLayout
	title="Misskeyについて"
	description="家猫ようかんのMisskeyサーバーの紹介・コンセプト"
>
	<h2>概要</h2>
	<p>
		当サーバーは、おひとりさま（または少人数）向けのMisskeyインスタンスです。<br
		/>
		ようかんの日常やつぶやき、ツイッターでは発信しないようなことも発信していきます。
	</p>

	<h2>紹介</h2>
	<ul>
		<li>ようかんのMisskeyの運用についてのノート</li>
		<li>ツイッターが止まったときに使う</li>
		<li>ぶいみみリレーに参加してVRChatの活動を共有する</li>
	</ul>

	<h2>サーバーの状態</h2>
	<div class={statusContainer}>
		{
			isOnline ? (
				<>
					<div
						class={statusDot}
						style="background-color: #4ade80; box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);"
					/>
					<span style="color: #16a34a;">サーバー稼働中 (Online)</span>
				</>
			) : (
				<>
					<div
						class={statusDot}
						style="background-color: #ef4444; box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);"
					/>
					<span style="color: #dc2626;">
						サーバー停止中 (Offline) もしくはアクセス不可
					</span>
				</>
			)
		}
	</div>

</MisskeyLayout>
