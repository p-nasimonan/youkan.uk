---
import MisskeyLayout from "../../components/misskey/MisskeyLayout.astro";
import ActivityChart from "../../components/misskey/ActivityChart.astro";
import StackedChart from "../../components/misskey/StackedChart.astro";
import { css } from "@styled/css";

const API    = "https://mi.youkan.uk/api";
const SPAN   = "hour";
const LIMIT  = 48;

const post = (path: string, body: object) =>
	fetch(`${API}/${path}`, {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify(body),
	});

// 全エンドポイントを並列取得
const [metaRes, instanceRes, apRes, fedRes, activeRes] = await Promise.allSettled([
	post("meta",                  { detail: false }),
	post("charts/instance",       { span: SPAN, limit: LIMIT, host: "" }),
	post("charts/ap-request",     { span: SPAN, limit: LIMIT }),
	post("charts/federation",     { span: SPAN, limit: LIMIT }),
	post("charts/active-users",   { span: SPAN, limit: LIMIT }),
]);

const isOnline = metaRes.status === "fulfilled" && metaRes.value.ok;

// --- 型定義 ---
type InstanceChart = {
	notes:    { total: number[]; inc: number[]; diffs: { normal: number[]; reply: number[]; renote: number[]; withFile: number[] } };
	users:    { total: number[]; inc: number[] };
	requests: { succeeded: number[]; failed: number[]; received: number[] };
	drive:    { totalFiles: number[]; incFiles: number[] };
};
type ApChart     = { deliverSucceeded: number[]; deliverFailed: number[]; inboxReceived: number[] };
type FedChart    = { deliveredInstances: number[]; inboxInstances: number[]; stalled: number[] };
type ActiveChart = { read: number[]; write: number[]; readWrite: number[] };

async function tryJson<T>(res: PromiseSettledResult<Response>): Promise<T | null> {
	if (res.status !== "fulfilled" || !res.value.ok) return null;
	try { return (await res.value.json()) as T; } catch { return null; }
}

const [instance, ap, fed, active] = await Promise.all([
	tryJson<InstanceChart>(instanceRes),
	tryJson<ApChart>(apRes),
	tryJson<FedChart>(fedRes),
	tryJson<ActiveChart>(activeRes),
]);

// oldest→newest に reverse
const rev = (arr: number[]) => [...arr].reverse();

// サマリー
const totalNotes = instance?.notes.total[0] ?? 0;
const totalUsers = instance?.users.total[0] ?? 0;

// ------- スタイル -------
const statusContainer = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "0.8rem",
	padding: "0.6rem 1.2rem",
	backgroundColor: "rgba(240,240,240,0.8)",
	borderRadius: "12px",
	marginBottom: "2rem",
	fontWeight: "bold",
	fontSize: "0.95rem",
});
const statusDot = css({ width: "10px", height: "10px", borderRadius: "50%", flexShrink: 0 });

const statsRow = css({ display: "flex", gap: "1rem", marginBottom: "2rem", flexWrap: "wrap" });
const statCard = css({
	flex: "1",
	minWidth: "120px",
	background: "linear-gradient(135deg,rgba(253,242,248,0.9),rgba(235,244,255,0.9))",
	borderRadius: "12px",
	padding: "0.9rem 1.2rem",
	textAlign: "center",
	border: "1px solid rgba(200,200,220,0.3)",
});
const statNum   = css({ fontSize: "1.6rem", fontWeight: "bold", color: "#5c7cfa", lineHeight: 1.1 });
const statLabel = css({ fontSize: "0.75rem", color: "#888", marginTop: "0.25rem" });

const chartSection = css({
	marginTop: "2rem",
	"& h3": {
		fontSize: "1rem",
		color: "#666",
		marginBottom: "1rem",
		paddingBottom: "0.4rem",
		borderBottom: "1px solid #eee",
	},
});
---

<MisskeyLayout
	title="Misskeyについて"
	description="家猫ようかんのMisskeyサーバーの紹介・コンセプト"
>
	<h2>概要</h2>
	<p>
		当サーバーは、おひとりさま（または少人数）向けのMisskeyインスタンスです。<br />
		ようかんの日常やつぶやき、ツイッターでは発信しないようなことも発信していきます。
	</p>

	<h2>紹介</h2>
	<ul>
		<li>ようかんのMisskeyの運用についてのノート</li>
		<li>ツイッターが止まったときに使う</li>
		<li>ぶいみみリレーに参加してVRChatの活動を共有する</li>
	</ul>

	<h2>サーバーの状態</h2>

	<div class={statusContainer}>
		{isOnline ? (
			<>
				<div class={statusDot} style="background:#4ade80;box-shadow:0 0 8px rgba(74,222,128,0.6);" />
				<span style="color:#16a34a;">サーバー稼働中 (Online)</span>
			</>
		) : (
			<>
				<div class={statusDot} style="background:#ef4444;box-shadow:0 0 8px rgba(239,68,68,0.6);" />
				<span style="color:#dc2626;">サーバー停止中 (Offline)</span>
			</>
		)}
	</div>

	{instance && (
		<div class={statsRow}>
			<div class={statCard}>
				<div class={statNum}>{totalNotes.toLocaleString()}</div>
				<div class={statLabel}>総ノート数</div>
			</div>
			<div class={statCard}>
				<div class={statNum}>{totalUsers.toLocaleString()}</div>
				<div class={statLabel}>総ユーザー数</div>
			</div>
		</div>
	)}

	<!-- ========== チャート群 ========== -->
	{(instance || ap || fed) && (
		<div class={chartSection}>

			{/* ノート内訳（積み上げ） */}
			{instance && (
				<>
					<h3>📝 ノート内訳（過去48時間）</h3>
					<StackedChart
						title="ノートの種類"
						unit="件"
						spanLabel="時間"
						series={[
							{ label: "通常",       data: rev(instance.notes.diffs.normal),   color: "#f9a8d4" },
							{ label: "リプライ",   data: rev(instance.notes.diffs.reply),    color: "#c4b5fd" },
							{ label: "リノート",   data: rev(instance.notes.diffs.renote),   color: "#7dd3fc" },
							{ label: "ファイル付", data: rev(instance.notes.diffs.withFile), color: "#86efac" },
						]}
					/>
				</>
			)}

			{/* APIリクエスト内訳 */}
			{instance && (
				<>
					<h3>🌐 APIリクエスト（過去48時間）</h3>
					<StackedChart
						title="リクエスト内訳"
						unit="件"
						spanLabel="時間"
						series={[
							{ label: "成功",   data: rev(instance.requests.succeeded), color: "#86efac" },
							{ label: "失敗",   data: rev(instance.requests.failed),    color: "#fca5a5" },
							{ label: "受信",   data: rev(instance.requests.received),  color: "#7dd3fc" },
						]}
					/>
				</>
			)}

			{/* ActivityPub送受信 */}
			{ap && (
				<>
					<h3>📡 ActivityPub（過去48時間）</h3>
					<StackedChart
						title="AP リクエスト"
						unit="件"
						spanLabel="時間"
						series={[
							{ label: "配送成功",   data: rev(ap.deliverSucceeded), color: "#86efac" },
							{ label: "配送失敗",   data: rev(ap.deliverFailed),    color: "#fca5a5" },
							{ label: "受信",       data: rev(ap.inboxReceived),    color: "#7dd3fc" },
						]}
					/>
				</>
			)}

			{/* 連合 */}
			{fed && (
				<>
					<h3>🔗 連合インスタンス（過去48時間）</h3>
					<StackedChart
						title="連合アクティビティ"
						unit="件"
						spanLabel="時間"
						series={[
							{ label: "配送先",   data: rev(fed.deliveredInstances), color: "#7dd3fc" },
							{ label: "受信元",   data: rev(fed.inboxInstances),     color: "#f9a8d4" },
							{ label: "失敗中",   data: rev(fed.stalled),            color: "#fca5a5" },
						]}
					/>
				</>
			)}

			{/* アクティブユーザー */}
			{active && (
				<>
					<h3>👤 アクティブユーザー（過去48時間）</h3>
					<ActivityChart
						data={rev(active.readWrite)}
						label="読み書きユーザー数"
						unit="人"
						color="pink"
						spanLabel="時間"
					/>
				</>
			)}

			{/* ドライブ */}
			{instance && (
				<>
					<h3>💾 ドライブ（過去48時間）</h3>
					<ActivityChart
						data={rev(instance.drive.incFiles)}
						label="新規ファイル数"
						unit="件"
						color="blue"
						spanLabel="時間"
					/>
				</>
			)}

		</div>
	)}

	{!instance && !ap && !fed && (
		<p style="color:#aaa;font-size:0.9rem;">チャートデータを取得できませんでした。</p>
	)}
</MisskeyLayout>
