---
import MisskeyLayout from "../../components/misskey/MisskeyLayout.astro";
import notFoundImg from "../../../src/assets/error/みすきー404.png";
---

<MisskeyLayout title="404 Not Found" description="指定されたページは存在しません。" hideNavLinks={true}>
	<div style="text-align: center; padding: 1rem 0;">
		<img src={notFoundImg.src} alt="404 Not Found" style="max-width: 100%; max-height: 400px; height: auto; border-radius: 16px; margin-bottom: 2rem; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" />
		<h2>ページが見つかりません。</h2>
		<p style="font-size: 1.1rem; margin-top: 1rem;">
			指定されたURLに該当するページはありません。<br />
			URLが間違っているか、ページが削除された可能性があります。
		</p>
		
		<div style="margin-top: 3rem;">
			<a href="https://mi.youkan.uk/" class="button-link">Misskeyタイムラインへ戻る</a>
			<a href="/misskey" class="button-link" style="background:#f8fafc; color:#64748b; border:1px solid #e2e8f0; margin-left: 1rem;">サーバー紹介へ</a>
		</div>
	</div>
</MisskeyLayout>
