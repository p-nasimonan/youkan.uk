---
import { css, cx } from "@styled/css";
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const { slug } = Astro.params;
const work = await getEntry("works", slug!);
if (!work) return Astro.redirect("/works");

const { title, description, url, githubUrl, image, tags } = work.data;
const fallbackImage = "/hero/videomock.png";
const imgSrc = image ?? fallbackImage;

const pageStyles = css({
	minHeight: "100vh",
	maxWidth: "900px",
	margin: "0 auto",
	padding: "6rem 2rem 8rem",
});

const backStyles = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "0.3rem",
	color: "#a07090",
	textDecoration: "none",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	fontSize: "0.95rem",
	marginBottom: "2.5rem",
	_hover: { textDecoration: "underline" },
});

const heroStyles = css({
	borderRadius: "24px",
	overflow: "hidden",
	aspectRatio: "16/9",
	marginBottom: "2.5rem",
	boxShadow: "0 8px 40px rgba(180,120,200,0.2)",
});

const imgStyles = css({
	width: "100%",
	height: "100%",
	objectFit: "cover",
	display: "block",
});

const titleStyles = css({
	fontSize: "2.5rem",
	fontWeight: "bold",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	color: "#4a4a4a",
	marginBottom: "1rem",
});

const tagsStyles = css({
	display: "flex",
	gap: "0.5rem",
	flexWrap: "wrap",
	marginBottom: "1.5rem",
});

const tagStyles = css({
	fontSize: "0.8rem",
	padding: "0.25rem 0.75rem",
	borderRadius: "999px",
	background: "linear-gradient(135deg, rgba(255,200,220,0.8), rgba(180,220,255,0.8))",
	color: "#7a3a7a",
	fontWeight: "bold",
	fontFamily: '"Zen Maru Gothic", sans-serif',
});

const descStyles = css({
	fontSize: "1.1rem",
	lineHeight: 1.8,
	color: "#555",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	marginBottom: "2.5rem",
});

const linksStyles = css({
	display: "flex",
	gap: "1rem",
	flexWrap: "wrap",
});

const linkStyles = css({
	display: "inline-flex",
	alignItems: "center",
	gap: "0.4rem",
	padding: "0.6rem 1.8rem",
	borderRadius: "999px",
	fontFamily: '"Zen Maru Gothic", sans-serif',
	fontWeight: "bold",
	fontSize: "0.95rem",
	textDecoration: "none",
	transition: "transform 0.2s ease, box-shadow 0.2s ease",
	_hover: {
		transform: "translateY(-2px)",
		boxShadow: "0 6px 20px rgba(180,120,200,0.3)",
	},
});

const linkPrimaryStyles = css({
	background: "linear-gradient(135deg, rgba(255,182,213,0.9), rgba(180,220,255,0.9))",
	color: "#5a3a5a",
	boxShadow: "0 3px 12px rgba(200,150,200,0.2)",
});

const linkGhStyles = css({
	background: "rgba(50,50,50,0.85)",
	color: "white",
	boxShadow: "0 3px 12px rgba(0,0,0,0.15)",
});
---

<Layout title={`${title} — ようかんのホームページ`} description={description} ogImage={imgSrc.startsWith("/") ? imgSrc : undefined}>
	<div class={pageStyles}>
		<a href="/works" class={backStyles}>← 作品一覧に戻る</a>

		<div class={heroStyles}>
			<img src={imgSrc} alt={title} class={imgStyles} />
		</div>

		<h1 class={titleStyles}>{title}</h1>

		{tags.length > 0 && (
			<div class={tagsStyles}>
				{tags.map((t: string) => <span class={tagStyles}>{t}</span>)}
			</div>
		)}

		<p class={descStyles}>{description}</p>

		<div class={linksStyles}>
			{url && (
				<a href={url} target="_blank" rel="noopener noreferrer" class={cx(linkStyles, linkPrimaryStyles)}>
					サイトを開く →
				</a>
			)}
			{githubUrl && (
				<a href={githubUrl} target="_blank" rel="noopener noreferrer" class={cx(linkStyles, linkGhStyles)}>
					GitHub
				</a>
			)}
		</div>
	</div>
</Layout>
